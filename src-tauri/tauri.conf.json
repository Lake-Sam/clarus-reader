{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clarus Reader",
  "version": "0.2.1",
  "identifier": "org.clarus.reader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{
      "title": "Clarus Reader",
      "width": 1440,
      "height": 800,
      "minWidth": 980,
      "minHeight": 600,
      "center": true,
      "maximized": true,
      "fullscreen": false
      ,"decorations": false
    }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "shortDescription": "Read difficult PDFs with clarity",
    "longDescription": "A private PDF reader with offline definitions, plain-language explanations, and bring-your-own-key AI chat.",
    "copyright": "Copyright © 2026 Lake-Sam",
    "category": "Productivity",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"]
  }
}
